{
  "name": "apex-backend",
  "version": "1.0.0",
  "description": "APEX Backend API - Personal Intelligence Dashboard",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "cd supabase && supabase db push",
    "db:reset": "cd supabase && supabase db reset",
    "db:types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "keywords": ["apex", "health", "dashboard", "api"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "tsx": "^4.16.0"
  }
}
